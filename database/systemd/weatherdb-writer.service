[Unit]
Description=WeatherDB Writer — MQTT to MariaDB persistence
After=network.target mariadb.service
Wants=mariadb.service

[Service]
Type=simple
User=tempest
WorkingDirectory=/opt/weatherdatalogger/database
ExecStart=/opt/weatherdatalogger/database/venv/bin/python3 db_writer.py --config /opt/weatherdatalogger/config.ini
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
